diff --git a/tests/test_display_lookup.cpp b/tests/test_display_lookup.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..22e96f3dbf54adbcc4d9825bf33ab2446124c2fa
--- /dev/null
+++ b/tests/test_display_lookup.cpp
@@ -0,0 +1,60 @@
+#include <catch2/catch_test_macros.hpp>
+
+#include "Script/Script.h"
+
+using namespace gamescope;
+
+TEST_CASE("Known-display matching receives fixed-panel identity", "[display]")
+{
+    CScriptScopedLock script;
+    script->script( R"(
+        gamescope.config.known_displays.test_edidless_panel = {
+            allow_no_edid = true,
+            physical_size = { width_mm = 75, height_mm = 133 },
+            matches = function(display)
+                if display.vendor == "" and
+                   display.product == 0 and
+                   display.model == "" and
+                   display.data_string == "" and
+                   display.connector == "DSI-1" and
+                   display.device_id == "ayn-odin-3" and
+                   display.internal and
+                   not display.has_edid then
+                    return 100000
+                end
+                return -1
+            end,
+        }
+    )" );
+
+    const GamescopeDisplayLookupInfo panel
+    {
+        .vendor = "",
+        .product = 0,
+        .model = "",
+        .dataString = "",
+        .connector = "DSI-1",
+        .deviceId = "ayn-odin-3",
+        .internal = true,
+        .hasEdid = false,
+    };
+
+    auto match = script.Manager().Gamescope().Config.LookupDisplay( script, panel );
+    REQUIRE( match.has_value() );
+    REQUIRE( match->first == "test_edidless_panel" );
+    REQUIRE( match->second.get_or( "allow_no_edid", false ) );
+    const sol::optional<sol::table> physicalSize = match->second["physical_size"];
+    REQUIRE( physicalSize.has_value() );
+    REQUIRE( physicalSize->get_or( "width_mm", 0 ) == 75 );
+    REQUIRE( physicalSize->get_or( "height_mm", 0 ) == 133 );
+
+    GamescopeDisplayLookupInfo wrongDevice = panel;
+    wrongDevice.deviceId = "not-an-odin";
+    REQUIRE_FALSE( script.Manager().Gamescope().Config.LookupDisplay( script, wrongDevice ) );
+
+    GamescopeDisplayLookupInfo external = panel;
+    external.internal = false;
+    REQUIRE_FALSE( script.Manager().Gamescope().Config.LookupDisplay( script, external ) );
+
+    script.Manager().Gamescope().Config.KnownDisplays["test_edidless_panel"] = sol::lua_nil;
+}
diff --git a/tests/test_edid.cpp b/tests/test_edid.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..7fee713cb609404565db465537c6575e6ed4e54c
--- /dev/null
+++ b/tests/test_edid.cpp
@@ -0,0 +1,165 @@
+#include <catch2/catch_test_macros.hpp>
+
+#include "backend.h"
+#include "color_helpers.h"
+#include "edid.h"
+
+#include <cmath>
+#include <cstdint>
+#include <memory>
+
+extern "C"
+{
+#include "libdisplay-info/info.h"
+#include "libdisplay-info/edid.h"
+#include "libdisplay-info/cta.h"
+}
+
+using namespace gamescope;
+
+TEST_CASE("Synthetic EDID round-trips calibrated chromaticity", "[edid][hdr]")
+{
+    const displaycolorimetry_t expected
+    {
+        .primaries = {
+            { 0.6800f, 0.3200f },
+            { 0.2650f, 0.6900f },
+            { 0.1500f, 0.0600f },
+        },
+        .white = { 0.3127f, 0.3290f },
+    };
+
+    const EdidModeInfo expectedMode
+    {
+        .clockKHz = 267843,
+        .hdisplay = 1080,
+        .hsyncStart = 1104,
+        .hsyncEnd = 1105,
+        .htotal = 1129,
+        .vdisplay = 1920,
+        .vsyncStart = 1948,
+        .vsyncEnd = 1949,
+        .vtotal = 1977,
+        // This is the misleading geometry reported by the live Odin 3 kernel.
+        .physicalWidthMm = 136,
+        .physicalHeightMm = 68,
+        .hsyncPositive = true,
+        .vsyncPositive = true,
+    };
+
+    // The native-portrait dimensions come from the root-qualified profile,
+    // not the connector report. Rotation must expose a landscape client EDID.
+    const EdidPhysicalSize qualifiedPhysicalSize
+    {
+        .widthMm = 75,
+        .heightMm = 133,
+    };
+
+    const std::vector<uint8_t> edid = GenerateSimpleEdid(
+        expectedMode, &expected, &qualifiedPhysicalSize );
+    REQUIRE( edid.size() >= 128 );
+
+    uint8_t checksum = 0;
+    for ( size_t i = 0; i < 128; i++ )
+        checksum += edid[i];
+    REQUIRE( checksum == 0 );
+
+    const uint8_t *dtd = &edid[0x36];
+    const uint32_t pixelClockKHz = ( dtd[0] | ( dtd[1] << 8 ) ) * 10;
+    const uint32_t hactive = dtd[2] | ( ( dtd[4] >> 4 ) << 8 );
+    const uint32_t hblank = dtd[3] | ( ( dtd[4] & 0xf ) << 8 );
+    const uint32_t vactive = dtd[5] | ( ( dtd[7] >> 4 ) << 8 );
+    const uint32_t vblank = dtd[6] | ( ( dtd[7] & 0xf ) << 8 );
+    const double refreshHz = ( pixelClockKHz * 1000.0 ) /
+        ( ( hactive + hblank ) * ( vactive + vblank ) );
+    CHECK( hactive == expectedMode.hdisplay );
+    CHECK( vactive == expectedMode.vdisplay );
+    CHECK( std::abs( static_cast<int64_t>( pixelClockKHz ) - expectedMode.clockKHz ) <= 5 );
+    CHECK( std::fabs( refreshHz - 120.0 ) < 0.01 );
+
+    BackendConnectorHDRInfo hdrInfo{};
+    hdrInfo.bExposeHDRSupport = true;
+    hdrInfo.eOutputEncodingEOTF = EOTF_Gamma22;
+    hdrInfo.uMaxContentLightLevel = 650;
+    hdrInfo.uMaxFrameAverageLuminance = 400;
+    hdrInfo.uMinContentLightLevel = nits_to_u16_dark( 0.005f );
+
+    auto patched = PatchEdid( std::span<const uint8_t>{ edid.data(), edid.size() }, hdrInfo, false );
+    REQUIRE( patched.has_value() );
+    REQUIRE( patched->size() == edid.size() );
+    for ( size_t block = 0; block < patched->size() / 128; block++ )
+    {
+        checksum = 0;
+        for ( size_t i = 0; i < 128; i++ )
+            checksum += (*patched)[block * 128 + i];
+        REQUIRE( checksum == 0 );
+    }
+
+    auto rotated = PatchEdid( std::span<const uint8_t>{ edid.data(), edid.size() }, hdrInfo, true );
+    REQUIRE( rotated.has_value() );
+    const uint8_t *rotatedDtd = &(*rotated)[0x36];
+    const uint32_t rotatedHActive = rotatedDtd[2] | ( ( rotatedDtd[4] >> 4 ) << 8 );
+    const uint32_t rotatedHBlank = rotatedDtd[3] | ( ( rotatedDtd[4] & 0xf ) << 8 );
+    const uint32_t rotatedVActive = rotatedDtd[5] | ( ( rotatedDtd[7] >> 4 ) << 8 );
+    const uint32_t rotatedVBlank = rotatedDtd[6] | ( ( rotatedDtd[7] & 0xf ) << 8 );
+    const uint32_t rotatedHSize = rotatedDtd[12] | ( ( rotatedDtd[14] >> 4 ) << 8 );
+    const uint32_t rotatedVSize = rotatedDtd[13] | ( ( rotatedDtd[14] & 0xf ) << 8 );
+    const double rotatedRefreshHz = ( pixelClockKHz * 1000.0 ) /
+        ( ( rotatedHActive + rotatedHBlank ) * ( rotatedVActive + rotatedVBlank ) );
+    CHECK( rotatedHActive == expectedMode.vdisplay );
+    CHECK( rotatedVActive == expectedMode.hdisplay );
+    CHECK( rotatedHBlank == expectedMode.vtotal - expectedMode.vdisplay );
+    CHECK( rotatedVBlank == expectedMode.htotal - expectedMode.hdisplay );
+    CHECK( rotatedHSize == qualifiedPhysicalSize.heightMm );
+    CHECK( rotatedVSize == qualifiedPhysicalSize.widthMm );
+    CHECK( rotatedHSize > rotatedVSize );
+    CHECK( (*rotated)[0x15] == 13 );
+    CHECK( (*rotated)[0x16] == 8 );
+    CHECK( std::fabs( rotatedRefreshHz - 120.0 ) < 0.01 );
+
+    std::unique_ptr<di_info, decltype( &di_info_destroy )> info(
+        di_info_parse_edid( patched->data(), patched->size() ),
+        &di_info_destroy );
+    REQUIRE( info != nullptr );
+
+    const di_edid *parsedEdid = di_info_get_edid( info.get() );
+    REQUIRE( parsedEdid != nullptr );
+    const di_edid_chromaticity_coords *parsed = di_edid_get_chromaticity_coords( parsedEdid );
+    REQUIRE( parsed != nullptr );
+
+    constexpr float kEdid10BitPrecision = ( 1.0f / 1024.0f ) + 0.000001f;
+    CHECK( std::fabs( parsed->red_x - expected.primaries.r.x ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->red_y - expected.primaries.r.y ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->green_x - expected.primaries.g.x ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->green_y - expected.primaries.g.y ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->blue_x - expected.primaries.b.x ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->blue_y - expected.primaries.b.y ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->white_x - expected.white.x ) <= kEdid10BitPrecision );
+    CHECK( std::fabs( parsed->white_y - expected.white.y ) <= kEdid10BitPrecision );
+
+    const di_cta_colorimetry_block *colorimetry = nullptr;
+    const di_cta_hdr_static_metadata_block *hdrMetadata = nullptr;
+    const di_edid_ext *const *extensions = di_edid_get_extensions( parsedEdid );
+    for ( ; *extensions != nullptr; extensions++ )
+    {
+        const di_edid_cta *cta = di_edid_ext_get_cta( *extensions );
+        if ( !cta )
+            continue;
+
+        const di_cta_data_block *const *blocks = di_edid_cta_get_data_blocks( cta );
+        for ( ; *blocks != nullptr; blocks++ )
+        {
+            if ( di_cta_data_block_get_tag( *blocks ) == DI_CTA_DATA_BLOCK_COLORIMETRY )
+                colorimetry = di_cta_data_block_get_colorimetry( *blocks );
+            else if ( di_cta_data_block_get_tag( *blocks ) == DI_CTA_DATA_BLOCK_HDR_STATIC_METADATA )
+                hdrMetadata = di_cta_data_block_get_hdr_static_metadata( *blocks );
+        }
+    }
+
+    REQUIRE( colorimetry != nullptr );
+    REQUIRE( colorimetry->bt2020_rgb );
+    REQUIRE( hdrMetadata != nullptr );
+    REQUIRE( hdrMetadata->eotfs != nullptr );
+    REQUIRE( hdrMetadata->eotfs->pq );
+    CHECK( std::fabs( hdrMetadata->desired_content_min_luminance - 0.005f ) < 0.002f );
+}
