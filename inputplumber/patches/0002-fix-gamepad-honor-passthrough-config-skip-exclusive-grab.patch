From 61abdb8600af260025e47260f35af580902e8617 Mon Sep 17 00:00:00 2001
From: Ga1dz1 <5482gfbt@gmail.com>
Date: Sat, 18 Jul 2026 11:01:20 -0700
Subject: [PATCH] fix(gamepad): honor passthrough config, skip exclusive grab

GamepadEventDevice::new() unconditionally called device.grab(), unlike
KeyboardEventDevice which already respects the source device's
'passthrough' yaml option. This left passthrough: true silently inert
for any gamepad-classified source (Retroid Mini V2's raw MCU gamepad
included), so a second reader of the same node (armada-stick-led's
reactive LED mode) never received any events - the device stayed
exclusively grabbed the whole time regardless of the yaml setting.
Mirror keyboard.rs's handling: skip grab() when passthrough is set.
---
 src/input/source/evdev.rs         |  2 +-
 src/input/source/evdev/gamepad.rs | 10 +++++++++-
 2 files changed, 10 insertions(+), 2 deletions(-)

diff --git a/src/input/source/evdev.rs b/src/input/source/evdev.rs
index 2db1cad..e881143 100644
--- a/src/input/source/evdev.rs
+++ b/src/input/source/evdev.rs
@@ -144,7 +144,7 @@ impl EventDevice {
                 Ok(Self::Blocked(source_device))
             }
             DriverType::Gamepad => {
-                let device = GamepadEventDevice::new(device_info.clone(), capability_map)?;
+                let device = GamepadEventDevice::new(device_info.clone(), &conf, capability_map)?;
                 let source_device =
                     SourceDriver::new(composite_device, device, device_info.into(), conf);
                 Ok(Self::Gamepad(source_device))
diff --git a/src/input/source/evdev/gamepad.rs b/src/input/source/evdev/gamepad.rs
index de2661f..3d159a7 100644
--- a/src/input/source/evdev/gamepad.rs
+++ b/src/input/source/evdev/gamepad.rs
@@ -11,6 +11,7 @@ use packed_struct::types::SizedInteger;
 use packed_struct::PrimitiveEnum;
 
 use crate::config::capability_map::CapabilityMapConfigV2;
+use crate::config::SourceDevice;
 use crate::drivers::steam_deck::hid_report::{
     CommandType, PackedHapticReport, PackedRumbleReport, PadSide,
 };
@@ -43,12 +44,19 @@ impl GamepadEventDevice {
     /// Create a new [Gamepad] source device from the given udev info
     pub fn new(
         device_info: UdevDevice,
+        config: &Option<SourceDevice>,
         capability_map: Option<CapabilityMapConfigV2>,
     ) -> Result<Self, Box<dyn Error + Send + Sync>> {
         let path = device_info.devnode();
         log::debug!("Opening device at: {}", path);
         let mut device = Device::open(path.clone())?;
-        device.grab()?;
+
+        // Grab exclusive access to the device, unless passthrough is requested
+        // (matches KeyboardEventDevice's handling of the same option).
+        let should_passthru = config.as_ref().and_then(|c| c.passthrough).unwrap_or(false);
+        if !should_passthru {
+            device.grab()?;
+        }
 
         // Set the device to do non-blocking reads
         // TODO: use epoll to wake up when data is available
-- 
