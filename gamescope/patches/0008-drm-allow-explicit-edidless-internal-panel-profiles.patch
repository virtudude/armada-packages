+            : mode.physicalWidthMm;
+        const uint32_t physicalHeightMm = pPhysicalSizeOverride
+            ? pPhysicalSizeOverride->heightMm
+            : mode.physicalHeightMm;
+
+        if ( !mode.clockKHz || mode.clockKHz > 655350 ||
+             !mode.hdisplay || mode.hdisplay > 4095 ||
+             mode.hsyncStart < mode.hdisplay || mode.hsyncEnd < mode.hsyncStart || mode.htotal < mode.hsyncEnd ||
+             !mode.vdisplay || mode.vdisplay > 4095 ||
+             mode.vsyncStart < mode.vdisplay || mode.vsyncEnd < mode.vsyncStart || mode.vtotal < mode.vsyncEnd ||
+             physicalWidthMm > 4095 || physicalHeightMm > 4095 ||
+             ( pPhysicalSizeOverride && ( !physicalWidthMm || !physicalHeightMm ) ) )
+        {
+            return {};
+        }
+
+        const uint32_t hblank = mode.htotal - mode.hdisplay;
+        const uint32_t vblank = mode.vtotal - mode.vdisplay;
+        const uint32_t hsyncOffset = mode.hsyncStart - mode.hdisplay;
+        const uint32_t hsyncWidth = mode.hsyncEnd - mode.hsyncStart;
+        const uint32_t vsyncOffset = mode.vsyncStart - mode.vdisplay;
+        const uint32_t vsyncWidth = mode.vsyncEnd - mode.vsyncStart;
+        if ( !hblank || hblank > 4095 || !vblank || vblank > 4095 ||
+             hsyncOffset > 1023 || !hsyncWidth || hsyncWidth > 1023 ||
+             vsyncOffset > 63 || !vsyncWidth || vsyncWidth > 63 )
+        {
+            return {};
+        }
+
+        const uint32_t pixelClock10KHz = ( mode.clockKHz + 5 ) / 10;
+        if ( !pixelClock10KHz || pixelClock10KHz > UINT16_MAX )
+            return {};
+
+        std::vector<uint8_t> edid = GenerateSimpleEdid( mode.hdisplay, mode.vdisplay, pColorimetry );
+        uint8_t *dtd = &edid[0x36];
+        std::fill( dtd, dtd + EDID_BYTE_DESCRIPTOR_SIZE, 0 );
+
+        dtd[0] = pixelClock10KHz & 0xff;
+        dtd[1] = ( pixelClock10KHz >> 8 ) & 0xff;
+        dtd[2] = mode.hdisplay & 0xff;
+        dtd[3] = hblank & 0xff;
+        dtd[4] = ( ( mode.hdisplay >> 8 ) << 4 ) | ( hblank >> 8 );
+        dtd[5] = mode.vdisplay & 0xff;
+        dtd[6] = vblank & 0xff;
+        dtd[7] = ( ( mode.vdisplay >> 8 ) << 4 ) | ( vblank >> 8 );
+        dtd[8] = hsyncOffset & 0xff;
+        dtd[9] = hsyncWidth & 0xff;
+        dtd[10] = ( ( hsyncOffset >> 8 ) << 6 ) |
+                  ( ( hsyncWidth >> 8 ) << 4 ) |
+                  ( ( vsyncOffset >> 4 ) << 2 ) |
+                    ( vsyncWidth >> 4 );
+        dtd[11] = ( ( vsyncOffset & 0xf ) << 4 ) | ( vsyncWidth & 0xf );
+        dtd[12] = physicalWidthMm & 0xff;
+        dtd[13] = physicalHeightMm & 0xff;
+        dtd[14] = ( ( physicalWidthMm >> 8 ) << 4 ) | ( physicalHeightMm >> 8 );
+        dtd[17] = 0x18 |
+                  ( mode.vsyncPositive ? 0x04 : 0 ) |
+                  ( mode.hsyncPositive ? 0x02 : 0 );
+
+        edid[0x15] = physicalWidthMm && physicalHeightMm
+            ? std::min<uint32_t>( 255, ( physicalWidthMm + 5 ) / 10 )
+            : 0;
+        edid[0x16] = physicalWidthMm && physicalHeightMm
+            ? std::min<uint32_t>( 255, ( physicalHeightMm + 5 ) / 10 )
+            : 0;
+
+        // The inherited range descriptor describes the Deck base EDID, not
+        // this panel. Make it a neutral dummy descriptor; the exact preferred
+        // timing above and DRM's real mode list remain authoritative.
+        uint8_t *rangeDescriptor = &edid[0x5a];
+        std::fill( rangeDescriptor, rangeDescriptor + EDID_BYTE_DESCRIPTOR_SIZE, 0 );
+        rangeDescriptor[3] = 0x10;
+
+        patch_edid_checksum( &edid[0] );
+        return edid;
+    }
 }
