diff --git a/src/Backends/DRMComposition.h b/src/Backends/DRMComposition.h
new file mode 100644
index 0000000000000000000000000000000000000000..1210f78cf06c80a8161aea45eb82adc624c0bf5f
--- /dev/null
+++ b/src/Backends/DRMComposition.h
@@ -0,0 +1,27 @@
+#pragma once
+
+#include "../color_helpers.h"
+
+#include <cstdint>
+
+namespace gamescope
+{
+    // Without DRM hardware color management, direct scanout is only safe for
+    // one PQ layer targeting a PQ output. In particular, a Gamma 2.2 HDR panel
+    // needs the Vulkan color pipeline to map even a single PQ layer into the
+    // panel's native encoding.
+    constexpr bool DrmHdrOutputRequiresVulkanComposition(
+        bool bOutputHDREnabled,
+        bool bSupportsHardwareColorManagement,
+        EOTF eOutputEncodingEOTF,
+        uint32_t uLayerCount,
+        bool bBaseLayerIsHDR10PQ )
+    {
+        if ( !bOutputHDREnabled || bSupportsHardwareColorManagement )
+            return false;
+
+        return eOutputEncodingEOTF != EOTF_PQ ||
+            uLayerCount != 1 ||
+            !bBaseLayerIsHDR10PQ;
+    }
+}
diff --git a/tests/test_drm_composition.cpp b/tests/test_drm_composition.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..fc79946b4cec3f9f741b47d1af91c06212597d85
--- /dev/null
+++ b/tests/test_drm_composition.cpp
@@ -0,0 +1,19 @@
+#include <catch2/catch_test_macros.hpp>
+
+#include "Backends/DRMComposition.h"
+
+using namespace gamescope;
+
+TEST_CASE("Gamma 2.2 HDR cannot direct scan without hardware color management", "[drm][hdr]")
+{
+    // Regression: the old DRM path allowed this exact single-PQ-layer case to
+    // direct scan, bypassing the PQ-to-native-Gamma-2.2 Vulkan transform.
+    REQUIRE( DrmHdrOutputRequiresVulkanComposition( true, false, EOTF_Gamma22, 1, true ) );
+
+    REQUIRE_FALSE( DrmHdrOutputRequiresVulkanComposition( true, true, EOTF_Gamma22, 1, true ) );
+    REQUIRE_FALSE( DrmHdrOutputRequiresVulkanComposition( true, false, EOTF_PQ, 1, true ) );
+    REQUIRE_FALSE( DrmHdrOutputRequiresVulkanComposition( false, false, EOTF_Gamma22, 1, true ) );
+
+    REQUIRE( DrmHdrOutputRequiresVulkanComposition( true, false, EOTF_PQ, 2, true ) );
+    REQUIRE( DrmHdrOutputRequiresVulkanComposition( true, false, EOTF_PQ, 1, false ) );
+}
