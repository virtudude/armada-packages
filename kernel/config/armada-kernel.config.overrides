# CONFIG overrides on top of the arm64 defconfig: drivers and board support
# defconfig leaves off, plus features forced on. Merged by scripts/build-kernel.sh.

# ============== Qualcomm platform (built-in for DRM_MSM) ==============
# DRM_MSM=y (built-in): as a module it loads too late for the bootloader's live
# panel handoff → black screen. So everything it depends on is forced =y too.
CONFIG_DRM=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_SCHED=y
CONFIG_DRM_GPUVM=y
CONFIG_DRM_EXEC=y
CONFIG_DRM_DISPLAY_DP_HELPER=y
CONFIG_DRM_DISPLAY_DP_AUX_BUS=y
CONFIG_DRM_DISPLAY_DSC_HELPER=y
CONFIG_DRM_MIPI_DSI=y
CONFIG_DRM_BRIDGE_CONNECTOR=y
CONFIG_DRM_PANEL_BRIDGE=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_SIMPLEDRM=y

CONFIG_QCOM_OCMEM=y
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_MDT_LOADER=y
CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_UBWC_CONFIG=y
CONFIG_IOMMU_IO_PGTABLE=y
CONFIG_TRACE_GPU_MEM=y

CONFIG_SM_DISPCC_8550=y
CONFIG_SM_GPUCC_8550=y
CONFIG_SM_VIDEOCC_8550=y
CONFIG_SM_CAMCC_8550=y

CONFIG_PHY_QCOM_QMP_PCIE=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_QMP_UFS=y
CONFIG_PHY_QCOM_EDP=y

CONFIG_QCOM_QMI_HELPERS=y
CONFIG_QCOM_PDR_HELPERS=y
CONFIG_QCOM_PDR_MSG=y
CONFIG_QCOM_PD_MAPPER=y
CONFIG_QCOM_APR=y
CONFIG_MHI_BUS=y
CONFIG_QRTR=y
CONFIG_QRTR_SMD=y
CONFIG_QRTR_TUN=y
CONFIG_QRTR_MHI=y
CONFIG_RPMSG_CHAR=y
CONFIG_RPMSG_CTRL=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=y
CONFIG_QCOM_PMIC_GLINK=y
CONFIG_QCOM_FASTRPC=y
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_PBS=y
CONFIG_QCOM_SOCINFO=y
CONFIG_QCOM_STATS=y
CONFIG_QCOM_SPM=y
CONFIG_QCOM_LMH=y
CONFIG_QCOM_WDT=y
CONFIG_RESET_QCOM_PDC=y

CONFIG_INTERCONNECT_QCOM_OSM_L3=y
CONFIG_QCOM_ICC_BWMON=y

CONFIG_QCOM_SPMI_ADC5=y
CONFIG_QCOM_SPMI_ADC_TM5=y
CONFIG_QCOM_SPMI_TEMP_ALARM=y
CONFIG_QCOM_SPMI_VADC=y
CONFIG_QCOM_VADC_COMMON=y
CONFIG_POWER_RESET_QCOM_PON=y

CONFIG_SCSI_UFS_QCOM=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_SPI_QCOM_GENI=y
CONFIG_SPI_QCOM_QSPI=y
CONFIG_QCOM_GPI_DMA=y

CONFIG_UCSI_PMIC_GLINK=y
CONFIG_REGULATOR_QCOM_USB_VBUS=y

CONFIG_DRM_LONTIUM_LT8912B=y
CONFIG_DRM_PANEL_EDP=y

CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_COMBO=y
CONFIG_PHY_QCOM_EUSB2_REPEATER=y
CONFIG_PHY_SNPS_EUSB2=y
CONFIG_REGULATOR_QCOM_REFGEN=y

CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_QCOM_PMIC=y
CONFIG_TYPEC_MUX_NB7VPQ904M=y
CONFIG_TYPEC_MUX_FSA4480=y

CONFIG_DRM_AUX_BRIDGE=y
CONFIG_DRM_DISPLAY_CONNECTOR=y

CONFIG_DRM_MSM=y

CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_BACKLIGHT_QCOM_WLED=y

# ============== Display panels ==============
CONFIG_DRM_PANEL_AR06_4INCH=y               # AYANEO Pocket ACE
CONFIG_DRM_PANEL_AR02_3INCH=y               # AYANEO Pocket DMG
CONFIG_DRM_PANEL_AR11_5INCH=y               # AYANEO Pocket DS (lower panel)
CONFIG_DRM_PANEL_CHIPONE_ICNA35XX=y         # AYANEO Pocket EVO + Odin 2 Portal
CONFIG_DRM_PANEL_DDIC_CH13726A=y            # AYANEO Pocket S2K
CONFIG_DRM_PANEL_VISIONOX_VTDR6130_COG=y    # Retroid Pocket 6
CONFIG_DRM_PANEL_SYNAPTICS_TD4328=y         # AYN Odin 2
CONFIG_DRM_PANEL_BOE_XM91080G=y             # AYN Odin 2 Mini
CONFIG_DRM_PANEL_AYANEO_WT0600_2K=y         # AYN Thor

# ============== Input ==============
CONFIG_INPUT_JOYSTICK=y
CONFIG_INPUT_JOYDEV=m
CONFIG_JOYSTICK_RSINPUT=m

# ============== Touchscreens ==============
CONFIG_TOUCHSCREEN_HYNITRON_CSTXXX=m
CONFIG_TOUCHSCREEN_HYNITRON_ALL=m
CONFIG_RMI4_CORE=m
CONFIG_RMI4_I2C=m
CONFIG_RMI4_F11=y
CONFIG_RMI4_F12=y
CONFIG_RMI4_F30=y
CONFIG_TOUCHSCREEN_SYNAPTICS_DSX=m

# ============== LEDs / RGB ==============
CONFIG_LEDS_HTR3212=m

# ============== Haptics ==============
CONFIG_INPUT_QCOM_HV_HAPTICS=m              # required by common.dtsi

# ============== PWM ==============
CONFIG_PWM_SN3112=m

# ============== Panel power + backlight ==============
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_SGM3804=y
CONFIG_BACKLIGHT_SY7758=y
CONFIG_BACKLIGHT_ODIN2MINI=y
# =y not =m: a modular backlight PWM provider makes the panel bind late (from
# the rootfs). Gated by LEDS_CLASS_MULTICOLOR, which must be =y too.
CONFIG_LEDS_CLASS_MULTICOLOR=y
CONFIG_LEDS_QCOM_LPG=y

# ============== HID stack ==============
CONFIG_INPUT_UINPUT=y
CONFIG_HIDRAW=y
CONFIG_UHID=y
CONFIG_HID_STEAM=m
CONFIG_HID_PLAYSTATION=m
CONFIG_HID_SONY=m
CONFIG_HID_NINTENDO=m
CONFIG_HID_MICROSOFT=y
CONFIG_JOYSTICK_XPAD=m
CONFIG_JOYSTICK_XPAD_FF=y
CONFIG_JOYSTICK_XPAD_LEDS=y

# ============== Audio ==============
CONFIG_SND_SOC_AW88166=m
# absent snd-seq spams udev at boot — Fedora's snd-pcm modprobe rule pulls it in
CONFIG_SND_SEQUENCER=m

# ============== Gaming performance (scheduler / memory / sync) ==============
CONFIG_UCLAMP_TASK=y                         # armada-powerd sets cpu.uclamp.min per game
CONFIG_UCLAMP_TASK_GROUP=y
CONFIG_NTSYNC=y                              # Proton NT sync; off in arm64 defconfig
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y                     # bare LRU_GEN only builds MGLRU, this enables it
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y        # not defconfig's ALWAYS, which bloats FEX RAM
CONFIG_PSI=y                                 # Waydroid lmkd memory-pressure monitoring
CONFIG_PSI_DEFAULT_DISABLED=y                # opt in with psi=1

# ============== bootc / ostree / systemd ==============
CONFIG_EROFS_FS=m
CONFIG_EROFS_FS_BACKED_BY_FILE=y
CONFIG_OVERLAY_FS=m

CONFIG_SYSFB_SIMPLEFB=y
CONFIG_RD_ZSTD=y

CONFIG_UNICODE=y

# Fedora ships qcom firmware .xz-only (e.g. a740_sqe.fw); the loader needs these
CONFIG_FW_LOADER_COMPRESS=y
CONFIG_FW_LOADER_COMPRESS_XZ=y
CONFIG_FW_LOADER_COMPRESS_ZSTD=y

CONFIG_ZSMALLOC=m
CONFIG_ZRAM=m
CONFIG_ZRAM_BACKEND_ZSTD=y
CONFIG_ZRAM_BACKEND_LZ4=y
CONFIG_ZRAM_BACKEND_LZO=y
CONFIG_ZRAM_DEF_COMP_ZSTD=y
CONFIG_ZRAM_DEF_COMP="zstd"
CONFIG_CRYPTO_ZSTD=y

CONFIG_PKCS8_PRIVATE_KEY_PARSER=y           # =y silences a per-boot modprobe warning
CONFIG_CONFIGFS_FS=y
CONFIG_BTRFS_FS=m                           # bootc root default
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_FANOTIFY=y                           # ostree file-change tracking
CONFIG_BINFMT_MISC=m                        # FEX x86 translation registration
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y                   # hard dep of SECURITY_SELINUX
CONFIG_SECURITY_SELINUX=y
CONFIG_BPF_SYSCALL=y
CONFIG_CGROUP_BPF=y

# ============== SM8650 (AYANEO Pocket S2, KONKR Pocket FIT) ==============
# No SM_DISPCC_8650: display clock is the combined dispcc-sm8550.c (=y above).
CONFIG_SM_GCC_8650=y
CONFIG_SM_GPUCC_8650=y
CONFIG_SM_TCSRCC_8650=y
CONFIG_SM_CAMCC_8650=y
CONFIG_PINCTRL_SM8650=y
CONFIG_INTERCONNECT_QCOM_SM8650=y
CONFIG_DRM_PANEL_AR14=y                     # KONKR Pocket FIT
CONFIG_TOUCHSCREEN_CHIPONE_TDDI=m           # KONKR Pocket FIT (ICNL9922C)
CONFIG_TOUCHSCREEN_GOODIX=m                 # Pocket S2 + Pocket DS
CONFIG_ATH12K=m                             # WCN7850/WCN7860 Wi-Fi (SM8650 + SM8750)

# ============== SM8750 (AYN Odin 3) ==============
# gpucc is added by a patch (see patches/); the icna3520 panel reuses
# DRM_PANEL_CHIPONE_ICNA35XX above.
CONFIG_SM_GCC_8750=y
CONFIG_SM_DISPCC_8750=y
CONFIG_SM_GPUCC_8750=y
CONFIG_SM_VIDEOCC_8750=y
CONFIG_SM_TCSRCC_8750=y
CONFIG_PINCTRL_SM8750=y
CONFIG_INTERCONNECT_QCOM_SM8750=y
CONFIG_BT_QCA=m

CONFIG_DEVFREQ_GOV_PERFORMANCE=y

# ============== Removable + network filesystems ==============
CONFIG_EXFAT_FS=m
CONFIG_NLS_UTF8=y
CONFIG_NTFS3_FS=m
CONFIG_CIFS=m

# ============== Controller rumble ==============
CONFIG_NINTENDO_FF=y
CONFIG_PLAYSTATION_FF=y
CONFIG_SONY_FF=y
CONFIG_STEAM_FF=y

# ============== Bluetooth peripherals ==============
CONFIG_BT_LE=y
CONFIG_BT_RFCOMM=m

# ============== Waydroid ==============
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_IPV6=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_NET_KEY=y
CONFIG_XFRM_USER=y

# ============== netfilter / nftables (firewalld, Tailscale, WireGuard) ==============
CONFIG_NF_CONNTRACK=m
CONFIG_NF_NAT=m
CONFIG_NETFILTER_XTABLES=m
CONFIG_NF_TABLES=m
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=m
CONFIG_NFT_NAT=m
CONFIG_NFT_MASQ=m
CONFIG_NFT_REDIR=m
CONFIG_NFT_REJECT=m
CONFIG_NFT_REJECT_INET=m
CONFIG_NFT_COMPAT=m
CONFIG_NFT_LIMIT=m
CONFIG_NFT_LOG=m
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=m
CONFIG_NETFILTER_XT_MATCH_COMMENT=m
CONFIG_NETFILTER_XT_MATCH_MARK=m
CONFIG_NETFILTER_XT_TARGET_MARK=m
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=m
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_WIREGUARD=m
