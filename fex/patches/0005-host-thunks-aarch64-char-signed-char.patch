From: ROCKNIX
Subject: ThunkLibs: add signed-char* template specializations for aarch64

aarch64 defaults `char` to unsigned, so template specializations for
`char*` don't satisfy C++ overload resolution when callers pass
`signed char*`. Add explicit conversions to bridge.

Regenerated from ROCKNIX's 0005-host-thunks-aarch64-char-signed-char.patch
because their hunk header was off by 2 lines vs our checkout of FEX
commit a04b0241 (their @@ -446 vs actual @@ -448). Content byte-identical;
only the line numbers differ.

--- a/ThunkLibs/include/common/Host.h
+++ b/ThunkLibs/include/common/Host.h
@@ -448,6 +448,20 @@
     return (guest_layout<uint8_t*>)reinterpret_cast<const host_to_guest_convertible<uint8_t*>&>(*this);
   }

+  operator guest_layout<const signed char*>() const requires (std::is_same_v<T, const char*>)
+  {
+    guest_layout<const signed char*> ret;
+    ret.data = reinterpret_cast<uintptr_t>(from.data);
+    return ret;
+  }
+
+  operator guest_layout<signed char*>() const requires (std::is_same_v<T, char*>)
+  {
+    guest_layout<signed char*> ret;
+    ret.data = reinterpret_cast<uintptr_t>(from.data);
+    return ret;
+  }
+
   // Make guest_layout of "wchar_t" and "uint32_t" interoperable
   operator guest_layout<uint32_t*>() const requires (std::is_same_v<T, wchar_t*>)
   {
