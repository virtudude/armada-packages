From 46f3ded8dc0dd60d0584cedfe448fb62995ecd29 Mon Sep 17 00:00:00 2001
From: ROCKNIX <dev@rocknix.org>
Date: Fri, 15 May 2026 11:16:53 +0000
Subject: [PATCH v3] gpu: drm: panel: add wt0600 1080p single-DSI panel support

Changes from v2:
- Fix dsi[1]=NULL overwriting dual-DSI registration (use kzalloc default)
- Proper unified diff format generated by diff -u
---
 drivers/gpu/drm/panel/panel-wt0600-2k.c | 222 ++++++++++++++++++++++-----------
 1 file changed, 153 insertions(+), 69 deletions(-)

--- a/drivers/gpu/drm/panel/panel-wt0600-2k.c	2026-06-03 06:00:18.866607910 +0000
+++ b/drivers/gpu/drm/panel/panel-wt0600-2k.c	2026-06-03 05:59:35.407287935 +0000
@@ -23,7 +23,7 @@
 
 struct wt0600_panel {
 	struct drm_panel panel;
-	struct mipi_dsi_device *dsi[2];
+	struct mipi_dsi_device *dsi[2]; /* [1] NULL for single-DSI */
 	const struct panel_desc *desc;
 
 	struct gpio_desc *reset_gpio;
@@ -31,13 +31,33 @@
 	enum drm_panel_orientation orientation;
 };
 
-static const struct regulator_bulk_data wt0600_supplies[] = {
-	{ .supply = "vddio" },
-	{ .supply = "vci" },
-	{ .supply = "vdd" },
-	{ .supply = "avdd" },
+struct wt0600_regulator {
+	struct regulator *avdd;
+	struct regulator *vci;
+	struct regulator *vddio;
+	struct regulator *vdd;
 };
 
+static int wt0600_get_regulators(struct device *dev, struct wt0600_regulator *regs)
+{
+	regs->avdd = devm_regulator_get(dev, "avdd");
+	if (IS_ERR(regs->avdd))
+		return dev_err_probe(dev, PTR_ERR(regs->avdd),
+				     "Failed to get avdd regulator\n");
+
+	/* Optional supplies - SGM3804 generates these when configured via GPIO */
+	regs->vci = devm_regulator_get_optional(dev, "vci");
+	if (IS_ERR(regs->vci))
+		regs->vci = NULL;
+	regs->vddio = devm_regulator_get_optional(dev, "vddio");
+	if (IS_ERR(regs->vddio))
+		regs->vddio = NULL;
+	regs->vdd = devm_regulator_get_optional(dev, "vdd");
+	if (IS_ERR(regs->vdd))
+		regs->vdd = NULL;
+	return 0;
+}
+
 struct panel_desc {
 	const struct drm_display_mode *mode;
 	unsigned int lanes;
@@ -62,6 +82,19 @@
 	.type = DRM_MODE_TYPE_DRIVER | DRM_MODE_TYPE_PREFERRED,
 };
 
+static const struct drm_display_mode wt0600_1080p_mode = {
+	.clock = (1080 + 66 + 8 + 22) * (1920 + 9 + 2 + 14) * 60 / 1000,
+	.hdisplay = 1080,
+	.hsync_start = 1080 + 66,
+	.hsync_end = 1080 + 66 + 8,
+	.htotal = 1080 + 66 + 8 + 22,
+	.vdisplay = 1920,
+	.vsync_start = 1920 + 9,
+	.vsync_end = 1920 + 9 + 2,
+	.vtotal = 1920 + 9 + 2 + 14,
+	.type = DRM_MODE_TYPE_DRIVER | DRM_MODE_TYPE_PREFERRED,
+};
+
 static struct panel_desc wt0600_desc = {
 	.lanes = 4,
 	.width_mm = 74,
@@ -92,6 +125,21 @@
 	},
 };
 
+static struct panel_desc wt0600_1080p_desc = {
+	.lanes = 4,
+	.width_mm = 74,
+	.height_mm = 131,
+	.mode = &wt0600_1080p_mode,
+	.mode_flags = MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_BURST |
+		      MIPI_DSI_CLOCK_NON_CONTINUOUS | MIPI_DSI_MODE_LPM,
+	.format = MIPI_DSI_FMT_RGB888,
+	.dsi_info = {
+		.type = "wt0600-1080p-60hz",
+		.channel = 0,
+		.node = NULL,
+	},
+};
+
 static inline struct wt0600_panel *to_wt0600_panel(struct drm_panel *panel)
 {
 	return container_of(panel, struct wt0600_panel, panel);
@@ -107,69 +155,84 @@
 	msleep(55);
 }
 
-static int wt0600_on(struct wt0600_panel *ctx)
+static int wt0600_send_init_cmds(struct mipi_dsi_device *dsi)
 {
-	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi[0] };
-	struct mipi_dsi_multi_context dsi_ctx1 = { .dsi = ctx->dsi[1] };
+	int ret;
 
-	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx);
-	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx1);
-	mipi_dsi_msleep(&dsi_ctx, 150);
+	ret = mipi_dsi_dcs_exit_sleep_mode(dsi);
+	if (ret)
+		return ret;
+	msleep(50);
 
-	mipi_dsi_dcs_exit_sleep_mode_multi(&dsi_ctx);
-	mipi_dsi_dcs_exit_sleep_mode_multi(&dsi_ctx1);
-	mipi_dsi_msleep(&dsi_ctx, 50);
+	ret = mipi_dsi_dcs_set_display_on(dsi);
+	if (ret)
+		return ret;
+	msleep(150);
 
-	return dsi_ctx.accum_err;
+	return 0;
+}
+
+static int wt0600_send_init_cmds_all(struct wt0600_panel *ctx)
+{
+	int ret, i;
+	for (i = 0; i < (ctx->dsi[1] ? 2 : 1); i++) {
+		ret = wt0600_send_init_cmds(ctx->dsi[i]);
+		if (ret)
+			return ret;
+	}
+	return 0;
 }
 
 static int wt0600_disable(struct drm_panel *panel)
 {
 	struct wt0600_panel *ctx = to_wt0600_panel(panel);
-	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi[0] };
-	struct mipi_dsi_multi_context dsi_ctx1 = { .dsi = ctx->dsi[1] };
+	int i;
 
-	mipi_dsi_dcs_set_display_off_multi(&dsi_ctx);
-	mipi_dsi_dcs_set_display_off_multi(&dsi_ctx1);
-	mipi_dsi_msleep(&dsi_ctx, 50);
-
-	mipi_dsi_dcs_enter_sleep_mode_multi(&dsi_ctx);
-	mipi_dsi_dcs_enter_sleep_mode_multi(&dsi_ctx1);
-	mipi_dsi_msleep(&dsi_ctx, 120);
+	for (i = 0; i < (ctx->dsi[1] ? 2 : 1); i++) {
+		mipi_dsi_dcs_set_display_off(ctx->dsi[i]);
+		msleep(50);
+		mipi_dsi_dcs_enter_sleep_mode(ctx->dsi[i]);
+		msleep(120);
+	}
 
-	return dsi_ctx.accum_err;
+	return 0;
 }
 
 static int wt0600_prepare(struct drm_panel *panel)
 {
 	struct wt0600_panel *ctx = to_wt0600_panel(panel);
+	struct wt0600_regulator regs;
 	int ret;
 
-	ret = regulator_bulk_enable(ARRAY_SIZE(wt0600_supplies), ctx->supplies);
-	if (ret < 0)
+	ret = wt0600_get_regulators(panel->dev, &regs);
+	if (ret)
 		return ret;
+	regulator_enable(regs.avdd);
+	if (regs.vci) regulator_enable(regs.vci);
+	if (regs.vddio) regulator_enable(regs.vddio);
+	if (regs.vdd) regulator_enable(regs.vdd);
 
 	wt0600_reset(ctx);
 
-	ret = wt0600_on(ctx);
-	if (ret < 0) {
-		dev_err(panel->dev, "Failed to initialize panel: %d\n", ret);
-		gpiod_set_value_cansleep(ctx->reset_gpio, 1);
-		regulator_bulk_disable(ARRAY_SIZE(wt0600_supplies),
-				       ctx->supplies);
-		return ret;
-	}
-
-	return 0;
+	return wt0600_send_init_cmds_all(ctx);
 }
 
 static int wt0600_unprepare(struct drm_panel *panel)
 {
 	struct wt0600_panel *ctx = to_wt0600_panel(panel);
+	struct wt0600_regulator regs;
+	int ret;
+
+	ret = wt0600_get_regulators(panel->dev, &regs);
+	if (ret)
+		return ret;
 
 	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
 
-	regulator_bulk_disable(ARRAY_SIZE(wt0600_supplies), ctx->supplies);
+	regulator_disable(regs.avdd);
+	if (regs.vci) regulator_disable(regs.vci);
+	if (regs.vddio) regulator_disable(regs.vddio);
+	if (regs.vdd) regulator_disable(regs.vdd);
 
 	return 0;
 }
@@ -216,8 +279,9 @@
 {
 	struct device *dev = &dsi->dev;
 	struct wt0600_panel *ctx;
-	struct device_node *dsi1_node;
+	struct device_node *dsi1_node = NULL;
 	struct mipi_dsi_host *dsi1_host;
+	bool is_single_dsi;
 	int ret, i;
 
 	ctx = devm_kzalloc(dev, sizeof(*ctx), GFP_KERNEL);
@@ -229,36 +293,32 @@
 		return dev_err_probe(dev, -ENODEV,
 				     "Failed to get panel description\n");
 
-	ret = devm_regulator_bulk_get_const(&dsi->dev,
-					    ARRAY_SIZE(wt0600_supplies),
-					    wt0600_supplies, &ctx->supplies);
-	if (ret < 0)
-		return ret;
-
 	ctx->reset_gpio = devm_gpiod_get(dev, "reset", GPIOD_OUT_HIGH);
 	if (IS_ERR(ctx->reset_gpio))
 		return dev_err_probe(dev, PTR_ERR(ctx->reset_gpio),
 				     "Failed to get reset gpio\n");
 
-	/* Get second DSI host */
+	/*
+	 * Single-DSI panels don't have a second DSI host.
+	 * Determine by checking if of_graph_get_remote_node(..., 1, ...)
+	 * returns a valid node.
+	 */
+	is_single_dsi = true;
 	dsi1_node = of_graph_get_remote_node(dsi->dev.of_node, 1, -1);
-	if (!dsi1_node)
-		return dev_err_probe(
-			dev, -ENODEV,
-			"Failed to get remote node for second DSI\n");
-
-	dsi1_host = of_find_mipi_dsi_host_by_node(dsi1_node);
-	of_node_put(dsi1_node);
-	if (!dsi1_host)
-		return dev_err_probe(dev, -EPROBE_DEFER,
-				     "Failed to find second DSI host\n");
-
-	/* Register the second DSI device */
-	ctx->dsi[1] = devm_mipi_dsi_device_register_full(dev, dsi1_host,
-							 &ctx->desc->dsi_info);
-	if (IS_ERR(ctx->dsi[1]))
-		return dev_err_probe(dev, PTR_ERR(ctx->dsi[1]),
-				     "Failed to register second DSI device\n");
+	if (dsi1_node) {
+		is_single_dsi = false;
+		dsi1_host = of_find_mipi_dsi_host_by_node(dsi1_node);
+		of_node_put(dsi1_node);
+		if (!dsi1_host)
+			return dev_err_probe(dev, -EPROBE_DEFER,
+					     "Failed to find second DSI host\n");
+
+		ctx->dsi[1] = devm_mipi_dsi_device_register_full(dev, dsi1_host,
+								  &ctx->desc->dsi_info);
+		if (IS_ERR(ctx->dsi[1]))
+			return dev_err_probe(dev, PTR_ERR(ctx->dsi[1]),
+					     "Failed to register second DSI device\n");
+	}
 
 	/* Get panel orientation */
 	ret = of_drm_get_panel_orientation(dev->of_node, &ctx->orientation);
@@ -267,6 +327,8 @@
 				     "Failed to get panel orientation\n");
 
 	ctx->dsi[0] = dsi;
+	/* dsi[1] stays NULL for single-DSI (kzalloc), or set above for dual-DSI */
+
 	mipi_dsi_set_drvdata(dsi, ctx);
 
 	drm_panel_init(&ctx->panel, dev, &wt0600_panel_funcs,
@@ -279,8 +341,8 @@
 
 	drm_panel_add(&ctx->panel);
 
-	/* Configure and attach both DSI devices */
-	for (i = 0; i < ARRAY_SIZE(ctx->dsi); i++) {
+	/* Configure and attach DSI device(s) */
+	for (i = 0; i < (is_single_dsi ? 1 : 2); i++) {
 		ctx->dsi[i]->lanes = ctx->desc->lanes;
 		ctx->dsi[i]->format = ctx->desc->format;
 		ctx->dsi[i]->mode_flags = ctx->desc->mode_flags;
@@ -289,8 +351,7 @@
 		if (ret < 0) {
 			drm_panel_remove(&ctx->panel);
 			return dev_err_probe(dev, ret,
-					     "Failed to attach DSI device %d\n",
-					     i);
+					     "Failed to attach DSI device %d\n", i);
 		}
 	}
 
@@ -303,7 +364,8 @@
 	int i;
 
 	for (i = 0; i < ARRAY_SIZE(ctx->dsi); i++)
-		mipi_dsi_detach(ctx->dsi[i]);
+		if (ctx->dsi[i])
+			mipi_dsi_detach(ctx->dsi[i]);
 
 	drm_panel_remove(&ctx->panel);
 }
@@ -317,6 +379,10 @@
 		.compatible = "ayaneo,wt0630-2k",
 		.data = &wt0630_desc,
 	},
+	{
+		.compatible = "ayaneo,wt0600-1080p-60hz",
+		.data = &wt0600_1080p_desc,
+	},
 	{}
 };
 MODULE_DEVICE_TABLE(of, wt0600_of_match);
