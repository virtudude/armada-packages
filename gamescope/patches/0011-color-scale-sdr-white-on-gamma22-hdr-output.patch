diff --git a/src/HDRGamma22.h b/src/HDRGamma22.h
new file mode 100644
index 0000000..5018e6e
--- /dev/null
+++ b/src/HDRGamma22.h
@@ -0,0 +1,42 @@
+#pragma once
+
+#include "color_helpers.h"
+
+#include <limits>
+
+namespace gamescope
+{
+    constexpr bool ColorMgmtLutsAreCurrent(
+        bool bColorMgmtConfigCurrent,
+        bool bLutsInitialized,
+        bool bCachedTraditionalHDROutput,
+        bool bTraditionalHDROutput )
+    {
+        return bColorMgmtConfigCurrent && bLutsInitialized &&
+            bCachedTraditionalHDROutput == bTraditionalHDROutput;
+    }
+
+    // A traditional-HDR panel is driven in its native Gamma 2.2 encoding, so
+    // SDR white must be scaled into the panel's HDR luminance range explicitly.
+    // PQ outputs already encode flSDROnHDRBrightness in the transfer function.
+    constexpr float Gamma22HdrSDRInputScale(
+        bool bTraditionalHDROutput,
+        EOTF eOutputEncodingEOTF,
+        float flSDRWhiteNits,
+        float flPanelPeakNits )
+    {
+        if ( !bTraditionalHDROutput || eOutputEncodingEOTF != EOTF_Gamma22 ||
+             !( flSDRWhiteNits >= 1.0f ) ||
+             !( flSDRWhiteNits <= std::numeric_limits<float>::max() ) ||
+             !( flPanelPeakNits >= 1.0f ) ||
+             !( flPanelPeakNits <= std::numeric_limits<float>::max() ) )
+        {
+            return 1.0f;
+        }
+
+        const float flClampedSDRWhiteNits = flSDRWhiteNits < flPanelPeakNits
+            ? flSDRWhiteNits
+            : flPanelPeakNits;
+        return flClampedSDRWhiteNits / flPanelPeakNits;
+    }
+}
