+armada_device_disk()
+{
+    local dev="$1"
+    local real
+    local name
+    local parent
+
+    real=$(readlink -f "${dev}" 2>/dev/null) || return 1
+    while read -r name parent; do
+        [[ "${name}" == "${real}" ]] || continue
+        if [[ -n "${parent}" ]]; then
+            basename "${parent}"
+        else
+            basename "${real}"
+        fi
+        return 0
+    done < <(lsblk -nrpo NAME,PKNAME 2>/dev/null)
+
+    parent=$(lsblk -no PKNAME "${real}" 2>/dev/null | head -n1 || true)
+    if [[ -n "${parent}" ]]; then
+        basename "${parent}"
+    else
+        basename "${real}"
+    fi
+}
+
+armada_disk_from_majmin()
+{
+    local majmin="$1"
+    local name
+    local current
+    local parent
+
+    while read -r name current parent; do
+        [[ "${current}" == "${majmin}" ]] || continue
+        if [[ -n "${parent}" ]]; then
+            basename "${parent}"
+        else
+            basename "${name}"
+        fi
+        return 0
+    done < <(lsblk -nrpo NAME,MAJ:MIN,PKNAME 2>/dev/null)
+
+    return 1
+}
+
+armada_mount_source_disk()
+{
+    local target="$1"
+    local source
+    local majmin
+
+    source=$(findmnt -rn -o SOURCE --target "${target}" 2>/dev/null | head -n1 || true)
+    if [[ "${source}" == /dev/* ]]; then
+        source="${source%%[*}"
+        armada_device_disk "${source}"
+        return $?
+    fi
+
+    majmin=$(findmnt -rn -o MAJ:MIN --target "${target}" 2>/dev/null | head -n1 || true)
+    [[ -n "${majmin}" ]] || return 1
+    armada_disk_from_majmin "${majmin}"
+}
+
+armada_device_majmin()
+{
+    local dev="$1"
+    local real
+    local name
+    local current
+
+    real=$(readlink -f "${dev}" 2>/dev/null) || return 1
+    while read -r name current; do
+        [[ "${name}" == "${real}" ]] || continue
+        printf '%s\n' "${current}"
+        return 0
+    done < <(lsblk -nrpo NAME,MAJ:MIN 2>/dev/null)
+
+    return 1
+}
+
+armada_is_mounted_device()
+{
+    local dev="$1"
+    local majmin
+
+    majmin=$(armada_device_majmin "${dev}") || return 1
+    findmnt -rn -o MAJ:MIN 2>/dev/null | grep -Fxq "${majmin}"
+}
+
+armada_is_system_storage_device()
+{
+    local dev="$1"
+    local disk
+    local target
+    local source_disk
+
+    disk=$(armada_device_disk "${dev}") || return 1
+
+    for target in / /var /sysroot /etc /boot /boot/efi; do
+        source_disk=$(armada_mount_source_disk "${target}" || true)
+        [[ -n "${source_disk}" ]] || continue
+        if [[ "${disk}" == "${source_disk}" ]]; then
+            return 0
+        fi
+    done
+
+    return 1
+}
+
+armada_is_sd_storage_device()
+{
+    local dev="$1"
+    local disk
+
+    disk=$(armada_device_disk "${dev}") || return 1
+    [[ "${disk}" =~ ^mmcblk[0-9]+$ ]] || return 1
+    [[ -r "/sys/block/${disk}/device/type" ]] || return 1
+    [[ "$(cat "/sys/block/${disk}/device/type")" == "SD" ]] || return 1
+}
